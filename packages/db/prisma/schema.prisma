generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Auth (Better Auth) ──────────────────────────────────────────────────────
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ─── User ────────────────────────────────────────────────────────────────────
enum UserRole {
  STUDENT
  COUNSELOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(STUDENT)
  fcmToken      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  studentProfile   StudentProfile?
  counselorProfile CounselorProfile?
  sentMessages     Message[]         @relation("SentMessages")
  notifications    Notification[]
  referralsMade    Referral[]        @relation("ReferralsMade")
  referralReceived Referral?         @relation("ReferralReceived")
}

// ─── Student Profile ─────────────────────────────────────────────────────────
enum EducationLevel {
  HIGH_SCHOOL
  BACHELORS
  MASTERS
  PHD
}

model StudentProfile {
  id                   String         @id @default(cuid())
  userId               String         @unique
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetCountries      String[]       @default([])
  targetSubjects       String[]       @default([])
  budgetMin            Int?
  budgetMax            Int?
  gpa                  Float?
  ieltsScore           Float?
  toeflScore           Int?
  satScore             Int?
  greScore             Int?
  completionPercent    Int            @default(0)
  preferredIntakeMonth String?
  preferredIntakeYear  Int?
  nationality          String?
  highestEducation     EducationLevel @default(HIGH_SCHOOL)
  workExperienceYears  Int            @default(0)
  assignedCounselorId  String?
  assignedCounselor    CounselorProfile? @relation(fields: [assignedCounselorId], references: [id])
  referralCode         String         @unique @default(cuid())
  referralBalance      Int            @default(0)
  profileEmbedding     Float[]        @default([])
  matchesUpdatedAt     DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  applications      Application[]
  shortlistedCourses ShortlistedCourse[]
  bookingSessions   BookingSession[]
  conversations     Conversation[]     @relation("StudentConversations")
  matchResults      MatchResult[]
}

// ─── Counselor Profile ───────────────────────────────────────────────────────
model CounselorProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String?  @db.Text
  expertiseCountries String[] @default([])
  expertiseSubjects  String[] @default([])
  languages          String[] @default(["English"])
  calUsername        String?
  sessionRate        Int      @default(0)
  totalStudents      Int      @default(0)
  rating             Float?
  isAvailable        Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assignedStudents StudentProfile[]
  applications     Application[]
  bookingSessions  BookingSession[]
  conversations    Conversation[]   @relation("CounselorConversations")
}

// ─── University ──────────────────────────────────────────────────────────────
model University {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  country             String
  city                String
  logo                String?
  coverImage          String?
  description         String   @db.Text
  ranking             Int?
  website             String?
  established         Int?
  totalStudents       Int?
  internationalPercent Float?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  courses Course[]
}

// ─── Course ──────────────────────────────────────────────────────────────────
enum CourseLevel {
  UNDERGRADUATE
  POSTGRADUATE
  PHD
  DIPLOMA
  CERTIFICATE
  FOUNDATION
}

model Course {
  id                 String      @id @default(cuid())
  universityId       String
  university         University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name               String
  slug               String      @unique
  subject            String
  level              CourseLevel
  duration           Int
  durationUnit       String      @default("YEARS")
  tuitionFee         Int
  currency           String      @default("USD")
  applicationDeadline DateTime?
  startDate          DateTime?
  language           String      @default("English")
  requirements       String[]    @default([])
  hasScholarship     Boolean     @default(false)
  scholarshipDetails String?     @db.Text
  description        String      @db.Text
  isActive           Boolean     @default(true)
  vectorId           String?
  typesenseId        String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  applications       Application[]
  shortlistedCourses ShortlistedCourse[]
  matchResults       MatchResult[]
}

// ─── Application ─────────────────────────────────────────────────────────────
enum ApplicationStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  DOCUMENTS_REQUIRED
  ACCEPTED
  REJECTED
  WAITLISTED
  WITHDRAWN
}

model Application {
  id                String            @id @default(cuid())
  studentId         String
  student           StudentProfile    @relation(fields: [studentId], references: [id])
  courseId          String
  course            Course            @relation(fields: [courseId], references: [id])
  counselorId       String?
  counselor         CounselorProfile? @relation(fields: [counselorId], references: [id])
  status            ApplicationStatus @default(DRAFT)
  currentStep       Int               @default(1)
  totalSteps        Int               @default(5)
  personalInfo      Json?
  academicHistory   Json?
  personalStatement String?           @db.Text
  documentsUrls     String[]          @default([])
  submittedAt       DateTime?
  counselorNotes    String?           @db.Text
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

// ─── Shortlist ───────────────────────────────────────────────────────────────
model ShortlistedCourse {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  notes     String?
  createdAt DateTime       @default(now())

  @@unique([studentId, courseId])
}

// ─── AI Match Results ────────────────────────────────────────────────────────
model MatchResult {
  id           String         @id @default(cuid())
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  score        Float
  matchReasons String[]       @default([])
  createdAt    DateTime       @default(now())

  @@unique([studentId, courseId])
}

// ─── Booking Session ─────────────────────────────────────────────────────────
enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model BookingSession {
  id             String           @id @default(cuid())
  studentId      String
  student        StudentProfile   @relation(fields: [studentId], references: [id])
  counselorId    String
  counselor      CounselorProfile @relation(fields: [counselorId], references: [id])
  calBookingId   String?
  scheduledAt    DateTime
  duration       Int              @default(60)
  status         SessionStatus    @default(SCHEDULED)
  meetingUrl     String?
  notes          String?          @db.Text
  studentRating  Int?
  amountPaid     Int              @default(0)
  stripePaymentId String?
  reminderSent   Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// ─── Messaging ───────────────────────────────────────────────────────────────
model Conversation {
  id            String           @id @default(cuid())
  studentId     String
  student       StudentProfile   @relation("StudentConversations", fields: [studentId], references: [id])
  counselorId   String
  counselor     CounselorProfile @relation("CounselorConversations", fields: [counselorId], references: [id])
  lastMessageAt DateTime         @default(now())
  lastMessage   String?
  createdAt     DateTime         @default(now())

  messages Message[]

  @@unique([studentId, counselorId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String       @db.Text
  attachmentUrl  String?
  attachmentType String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// ─── Notifications ───────────────────────────────────────────────────────────
enum NotificationType {
  SESSION_REMINDER
  APPLICATION_UPDATE
  NEW_MESSAGE
  MATCH_READY
  REFERRAL_EARNED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

// ─── Referral ────────────────────────────────────────────────────────────────
model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referrer     User     @relation("ReferralsMade", fields: [referrerId], references: [id])
  referredId   String   @unique
  referred     User     @relation("ReferralReceived", fields: [referredId], references: [id])
  status       String   @default("PENDING")
  creditAmount Int      @default(500)
  createdAt    DateTime @default(now())
  completedAt  DateTime?
}

// ─── Newsletter ──────────────────────────────────────────────────────────────
model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  isActive    Boolean  @default(true)
  subscribedAt DateTime @default(now())
  tags        String[] @default([])
}

// ─── AI Chat History ─────────────────────────────────────────────────────────
model ChatHistory {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
